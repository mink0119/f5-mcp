# TMOS (iControl REST) endpoint
TMOS_HOST=192.168.47.55
TMOS_PORT=443
TMOS_AUTH_BASIC_B64=YWRtaW46YWRtaW4=
TMOS_VERIFY_TLS=false
TMOS_TIMEOUT_SECONDS=20

# 사용할 엔드포인트 유형 설정 (TMOS 또는 F5OS)
# 생략하면 기본값은 TMOS
# 주의: 각 도구가 명시적으로 endpoint_kind를 설정하므로 여기서 설정할 필요 없음
# F5_ENDPOINT_TYPE=F5OS

# Generic shorthand (optional).  If F5_HOST is set the values below will be
# used for either TMOS or F5OS, depending on F5_ENDPOINT_TYPE.
#F5_HOST=192.168.47.55
#F5_PORT=443
#F5_AUTH_BASIC_B64=YWRtaW46YWRtaW4=
#F5_VERIFY_TLS=false
#F5_TIMEOUT_SECONDS=20

# F5OS (RESTCONF) endpoint
F5OS_HOST=192.168.45.246
F5OS_PORT=8888
F5OS_AUTH_BASIC_B64=YWRtaW46bmN1cml0eTFAIw==
F5OS_VERIFY_TLS=false
F5OS_TIMEOUT_SECONDS=20

# Legacy keys (still supported for TMOS)
# IP_ADDRESS=192.168.47.55
# Authorization_string=YWRtaW46YWRtaW4=