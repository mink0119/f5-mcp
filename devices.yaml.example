# F5 장비 목록 — 소스 수정 없이 이 파일만 수정해 대상 장비/계정 관리
# 사용: 이 파일을 devices.yaml 로 복사한 뒤 IP·계정을 수정해 사용.
#       또는 환경변수 F5_DEVICES_FILE=/path/to/my-devices.yaml 로 경로 지정.
#
# 형식: devices 리스트. name 은 도구에서 device_name 으로 지정할 때 사용.
#       apply_to_all=True 시 이 목록 전체에 동일 설정이 적용됨.

devices:
  - name: f5-01
    host: 192.168.47.55
    port: 443
    username: admin
    password: changeme

  - name: f5-02
    host: 192.168.47.56
    port: 443
    username: admin
    password: changeme

# JSON 형식도 가능 (devices.json):
# {"devices": [{"name": "f5-01", "host": "192.168.47.55", "port": 443, "username": "admin", "password": "..."}]}
